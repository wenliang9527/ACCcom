<Window x:Class="ACCcom.ModbusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MODBUS" Height="650" Width="900"
        MinHeight="450" MinWidth="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBaseBrush}"
        Style="{StaticResource WindowStyle}">

    <TabControl Margin="10">
        <TabItem Header="Master">
            <Grid Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Operation Panel -->
                <Border Grid.Row="0" Background="{DynamicResource BgSurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="MODBUS RTU Master" Style="{StaticResource SectionHeader}" Margin="0,0,0,8" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Slave ID:" Style="{StaticResource Label}" />
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SlaveId}" Style="{StaticResource NumericBox}" />

                            <TextBlock Grid.Row="0" Grid.Column="3" Text="Function:" Style="{StaticResource Label}" />
                            <ComboBox Grid.Row="0" Grid.Column="4" ItemsSource="{Binding FunctionNames}" SelectedIndex="{Binding SelectedFunctionIndex}" Height="26" />

                            <TextBlock Grid.Row="0" Grid.Column="6" Text="Address:" Style="{StaticResource Label}" />
                            <TextBox Grid.Row="0" Grid.Column="7" Text="{Binding StartAddress}" Style="{StaticResource NumericBox}" />

                            <TextBlock Grid.Row="0" Grid.Column="9" Text="Quantity:" Style="{StaticResource Label}" />
                            <TextBox Grid.Row="0" Grid.Column="10" Text="{Binding Quantity}" Style="{StaticResource NumericBox}" />

                            <Button Grid.Row="0" Grid.Column="12" Content="Read" Command="{Binding ReadCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,6,0" />
                            <Button Grid.Row="0" Grid.Column="13" Content="Write" Command="{Binding WriteCommand}" Style="{StaticResource PrimaryButton}" />

                            <!-- Polling -->
                            <CheckBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Content="Auto Poll" IsChecked="{Binding IsPolling}" Margin="0,0,0,0" />
                            <TextBlock Grid.Row="2" Grid.Column="3" Text="Interval:" Style="{StaticResource Label}" Margin="8,0,0,0" />
                            <TextBox Grid.Row="2" Grid.Column="4" Text="{Binding PollIntervalMs}" Style="{StaticResource NumericBox}" />
                        </Grid>

                        <TextBlock Text="{Binding StatusText}" Style="{StaticResource Label}" Margin="0,6,0,0" Foreground="{DynamicResource AccentBrush}" />
                    </StackPanel>
                </Border>

                <!-- Register Data Grid -->
                <Border Grid.Row="1" Background="{DynamicResource BgSurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,0,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Registers" Style="{StaticResource SectionHeader}" Margin="0,0,0,6" />
                        <ListView Grid.Row="1" ItemsSource="{Binding Registers}" VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling" ScrollViewer.IsDeferredScrollingEnabled="True" Background="Transparent" BorderThickness="0">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Address" Width="80" DisplayMemberBinding="{Binding Address, StringFormat=0x{0:X4}}" />
                                    <GridViewColumn Header="Value (HEX)" Width="100" DisplayMemberBinding="{Binding Hex}" />
                                    <GridViewColumn Header="Value (DEC)" Width="100" DisplayMemberBinding="{Binding Dec}" />
                                    <GridViewColumn Header="Binary" Width="180" DisplayMemberBinding="{Binding Binary}" />
                                </GridView>
                            </ListView.View>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Foreground" Value="{DynamicResource InkPrimaryBrush}" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="FontFamily" Value="Consolas" />
                                    <Setter Property="FontSize" Value="12" />
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>
                    </Grid>
                </Border>

                <!-- Transaction Log -->
                <Border Grid.Row="3" Background="{DynamicResource BgSurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Transaction Log" Style="{StaticResource SectionHeader}" Margin="0,0,0,6" />
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,6">
                            <Button Content="CSV" Command="{Binding ExportCsvCommand}" Style="{StaticResource HeaderButton}" />
                            <Button Content="JSON" Command="{Binding ExportJsonCommand}" Style="{StaticResource HeaderButton}" Margin="4,0,0,0" />
                            <Button Content="TXT" Command="{Binding ExportTxtCommand}" Style="{StaticResource HeaderButton}" Margin="4,0,0,0" />
                            <Button Content="Clear" Command="{Binding ClearLogCommand}" Style="{StaticResource HeaderButton}" Margin="8,0,0,0" />
                        </StackPanel>
                        <ListView Grid.Row="1" Grid.ColumnSpan="2" ItemsSource="{Binding TransactionLog}" VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling" ScrollViewer.IsDeferredScrollingEnabled="True" Background="Transparent" BorderThickness="0">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Time" Width="80" DisplayMemberBinding="{Binding Timestamp, StringFormat=HH:mm:ss}" />
                                    <GridViewColumn Header="Slave" Width="60" DisplayMemberBinding="{Binding SlaveId}" />
                                    <GridViewColumn Header="Function" Width="100" DisplayMemberBinding="{Binding FunctionCode}" />
                                    <GridViewColumn Header="Request" Width="180" DisplayMemberBinding="{Binding RequestHex}" />
                                    <GridViewColumn Header="Response" Width="180" DisplayMemberBinding="{Binding ResponseHex}" />
                                    <GridViewColumn Header="Status" Width="120" DisplayMemberBinding="{Binding Status}" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>
        </TabItem>
        <TabItem Header="Slave">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="{DynamicResource BgSurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="MODBUS Slave Devices" Style="{StaticResource SectionHeader}" Margin="0,0,0,8" />
                        <WrapPanel>
                            <Button Content="Create Slave" Command="{Binding CreateSlaveCommand}" Style="{StaticResource PrimaryButton}" Width="120" Margin="0,0,6,0" />
                            <Button Content="Remove Selected" Command="{Binding RemoveSlaveCommand}" Style="{StaticResource PrimaryButton}" Width="120" />
                        </WrapPanel>
                    </StackPanel>
                </Border>
                <ListView Grid.Row="1" ItemsSource="{Binding SlaveDevices}" SelectedValue="{Binding SelectedSlaveId}" SelectedValuePath="Id"
                          Background="Transparent" BorderThickness="0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Slave ID" Width="80" DisplayMemberBinding="{Binding SlaveId}" />
                            <GridViewColumn Header="Transport" Width="100" DisplayMemberBinding="{Binding TransportType}" />
                            <GridViewColumn Header="Status" Width="80" DisplayMemberBinding="{Binding IsRunning}" />
                        </GridView>
                    </ListView.View>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Foreground" Value="{DynamicResource InkPrimaryBrush}" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="FontFamily" Value="Consolas" />
                            <Setter Property="FontSize" Value="12" />
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
                <Border Grid.Row="2" Background="{DynamicResource BgSurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,6,0,0">
                    <TextBlock Text="Transaction log shared with Master tab" Style="{StaticResource Label}" />
                </Border>
            </Grid>
        </TabItem>
    </TabControl>
</Window>
