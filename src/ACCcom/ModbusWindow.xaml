<Window x:Class="ACCcom.ModbusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ACCcom"
        Title="{Binding [Modbus.WindowTitle], Source={x:Static local:LanguageManager.Instance}}" Height="650" Width="900"
        MinHeight="450" MinWidth="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBaseBrush}"
        Style="{StaticResource WindowStyle}">

    <TabControl x:Name="MainTabControl" Margin="10">
        <TabItem Header="{Binding [Modbus.TabMaster], Source={x:Static local:LanguageManager.Instance}}">
            <Grid Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Operation Panel -->
                <Border Grid.Row="0" Background="{DynamicResource BgSurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="{Binding [Modbus.SectionMaster], Source={x:Static local:LanguageManager.Instance}}" Style="{StaticResource SectionHeader}" Margin="0,0,0,8" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding [Modbus.LabelSlaveId], Source={x:Static local:LanguageManager.Instance}}" Style="{StaticResource Label}" />
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SlaveId}" Style="{StaticResource NumericBox}" />

                            <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding [Modbus.LabelFunction], Source={x:Static local:LanguageManager.Instance}}" Style="{StaticResource Label}" />
                            <ComboBox Grid.Row="0" Grid.Column="4" ItemsSource="{Binding FunctionNames}" SelectedIndex="{Binding SelectedFunctionIndex}" Height="26" />

                            <TextBlock Grid.Row="0" Grid.Column="6" Text="{Binding [Modbus.LabelAddress], Source={x:Static local:LanguageManager.Instance}}" Style="{StaticResource Label}" />
                            <TextBox Grid.Row="0" Grid.Column="7" Text="{Binding StartAddress}" Style="{StaticResource NumericBox}" />

                            <TextBlock Grid.Row="0" Grid.Column="9" Text="{Binding [Modbus.LabelQuantity], Source={x:Static local:LanguageManager.Instance}}" Style="{StaticResource Label}" />
                            <TextBox Grid.Row="0" Grid.Column="10" Text="{Binding Quantity}" Style="{StaticResource NumericBox}" />

                            <Button Grid.Row="0" Grid.Column="12" Content="{Binding [Modbus.ButtonRead], Source={x:Static local:LanguageManager.Instance}}" Command="{Binding ReadCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,6,0" />
                            <Button Grid.Row="0" Grid.Column="13" Content="{Binding [Modbus.ButtonWrite], Source={x:Static local:LanguageManager.Instance}}" Command="{Binding WriteCommand}" Style="{StaticResource PrimaryButton}" />

                            <!-- Polling -->
                            <CheckBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Content="{Binding [Modbus.CheckAutoPoll], Source={x:Static local:LanguageManager.Instance}}" IsChecked="{Binding IsPolling}" Margin="0,0,0,0" />
                            <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding [Modbus.LabelInterval], Source={x:Static local:LanguageManager.Instance}}" Style="{StaticResource Label}" Margin="8,0,0,0" />
                            <TextBox Grid.Row="2" Grid.Column="4" Text="{Binding PollIntervalMs}" Style="{StaticResource NumericBox}" />
                        </Grid>

                        <TextBox Text="{Binding StatusText}" Style="{StaticResource Label}" Margin="0,6,0,0" Foreground="{DynamicResource AccentBrush}"
                                  IsReadOnly="True" IsTabStop="False" BorderThickness="0" Background="Transparent" Padding="0" />
                    </StackPanel>
                </Border>

                <!-- Register Data Grid -->
                <Border Grid.Row="1" Background="{DynamicResource BgSurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,0,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="{Binding [Modbus.SectionRegisters], Source={x:Static local:LanguageManager.Instance}}" Style="{StaticResource SectionHeader}" Margin="0,0,0,6" />
                        <ListView Grid.Row="1" ItemsSource="{Binding Registers}" VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling" ScrollViewer.IsDeferredScrollingEnabled="True" Background="Transparent" BorderThickness="0">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="{Binding [Modbus.ColAddress], Source={x:Static local:LanguageManager.Instance}}" Width="80" DisplayMemberBinding="{Binding Address, StringFormat=0x{0:X4}}" />
                                    <GridViewColumn Header="{Binding [Modbus.ColValueHex], Source={x:Static local:LanguageManager.Instance}}" Width="100" DisplayMemberBinding="{Binding Hex}" />
                                    <GridViewColumn Header="{Binding [Modbus.ColValueDec], Source={x:Static local:LanguageManager.Instance}}" Width="100" DisplayMemberBinding="{Binding Dec}" />
                                    <GridViewColumn Header="{Binding [Modbus.ColBinary], Source={x:Static local:LanguageManager.Instance}}" Width="180" DisplayMemberBinding="{Binding Binary}" />
                                </GridView>
                            </ListView.View>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Foreground" Value="{DynamicResource InkPrimaryBrush}" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="FontFamily" Value="Consolas" />
                                    <Setter Property="FontSize" Value="12" />
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>
                    </Grid>
                </Border>

                <!-- Transaction Log -->
                <Border Grid.Row="3" Background="{DynamicResource BgSurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding [Modbus.SectionTransactionLog], Source={x:Static local:LanguageManager.Instance}}" Style="{StaticResource SectionHeader}" Margin="0,0,0,6" />
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,6">
                            <Button Content="{Binding [Button.CSV], Source={x:Static local:LanguageManager.Instance}}" Command="{Binding ExportCsvCommand}" Style="{StaticResource HeaderButton}" />
                            <Button Content="{Binding [Button.JSON], Source={x:Static local:LanguageManager.Instance}}" Command="{Binding ExportJsonCommand}" Style="{StaticResource HeaderButton}" Margin="4,0,0,0" />
                            <Button Content="{Binding [Button.TXT], Source={x:Static local:LanguageManager.Instance}}" Command="{Binding ExportTxtCommand}" Style="{StaticResource HeaderButton}" Margin="4,0,0,0" />
                            <Button Content="{Binding [Modbus.ButtonClear], Source={x:Static local:LanguageManager.Instance}}" Command="{Binding ClearLogCommand}" Style="{StaticResource HeaderButton}" Margin="8,0,0,0" />
                        </StackPanel>
                        <ListView Grid.Row="1" Grid.ColumnSpan="2" ItemsSource="{Binding TransactionLog}" VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling" ScrollViewer.IsDeferredScrollingEnabled="True" Background="Transparent" BorderThickness="0">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="{Binding [Modbus.ColTime], Source={x:Static local:LanguageManager.Instance}}" Width="80" DisplayMemberBinding="{Binding Timestamp, StringFormat=HH:mm:ss}" />
                                    <GridViewColumn Header="{Binding [Modbus.ColSlave], Source={x:Static local:LanguageManager.Instance}}" Width="60" DisplayMemberBinding="{Binding SlaveId}" />
                                    <GridViewColumn Header="{Binding [Modbus.ColFunction], Source={x:Static local:LanguageManager.Instance}}" Width="100" DisplayMemberBinding="{Binding FunctionCode}" />
                                    <GridViewColumn Header="{Binding [Modbus.ColRequest], Source={x:Static local:LanguageManager.Instance}}" Width="180" DisplayMemberBinding="{Binding RequestHex}" />
                                    <GridViewColumn Header="{Binding [Modbus.ColResponse], Source={x:Static local:LanguageManager.Instance}}" Width="180" DisplayMemberBinding="{Binding ResponseHex}" />
                                    <GridViewColumn Header="{Binding [Modbus.ColStatus], Source={x:Static local:LanguageManager.Instance}}" Width="120" DisplayMemberBinding="{Binding Status}" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>
        </TabItem>
        <TabItem Header="{Binding [Modbus.TabSlave], Source={x:Static local:LanguageManager.Instance}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="{DynamicResource BgSurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="{Binding [Modbus.SectionSlaveDevices], Source={x:Static local:LanguageManager.Instance}}" Style="{StaticResource SectionHeader}" Margin="0,0,0,8" />
                        <WrapPanel>
                            <Button Content="{Binding [Modbus.ButtonCreateSlave], Source={x:Static local:LanguageManager.Instance}}" Command="{Binding CreateSlaveCommand}" Style="{StaticResource PrimaryButton}" Width="120" Margin="0,0,6,0" />
                            <Button Content="{Binding [Modbus.ButtonRemoveSlave], Source={x:Static local:LanguageManager.Instance}}" Command="{Binding RemoveSlaveCommand}" Style="{StaticResource PrimaryButton}" Width="120" />
                        </WrapPanel>
                    </StackPanel>
                </Border>
                <ListView Grid.Row="1" ItemsSource="{Binding SlaveDevices}" SelectedValue="{Binding SelectedSlaveId}" SelectedValuePath="Id"
                          Background="Transparent" BorderThickness="0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="{Binding [Modbus.ColSlaveId], Source={x:Static local:LanguageManager.Instance}}" Width="80" DisplayMemberBinding="{Binding SlaveId}" />
                            <GridViewColumn Header="{Binding [Modbus.ColTransport], Source={x:Static local:LanguageManager.Instance}}" Width="100" DisplayMemberBinding="{Binding TransportType}" />
                            <GridViewColumn Header="{Binding [Modbus.ColSlaveStatus], Source={x:Static local:LanguageManager.Instance}}" Width="80" DisplayMemberBinding="{Binding IsRunning}" />
                        </GridView>
                    </ListView.View>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Foreground" Value="{DynamicResource InkPrimaryBrush}" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="FontFamily" Value="Consolas" />
                            <Setter Property="FontSize" Value="12" />
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
                <Border Grid.Row="2" Background="{DynamicResource BgSurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,6,0,0">
                    <TextBlock Text="{Binding [Modbus.TextSharedLog], Source={x:Static local:LanguageManager.Instance}}" Style="{StaticResource Label}" />
                </Border>
            </Grid>
        </TabItem>
        <TabItem Header="{Binding [Modbus.TabDashboard], Source={x:Static local:LanguageManager.Instance}}">
            <Grid x:Name="DashboardContainer">
                <TextBlock x:Name="DashboardPlaceholder" Text="{Binding [Modbus.DashboardLoading], Source={x:Static local:LanguageManager.Instance}}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource InkSecondaryBrush}" />
            </Grid>
        </TabItem>
    </TabControl>
</Window>