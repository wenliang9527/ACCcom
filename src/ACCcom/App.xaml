<Application x:Class="ACCcom.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:ACCcom.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <converters:BoolToOpenTextConverter x:Key="BoolToOpenText" />
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
            <converters:SeverityToColorConverter x:Key="SeverityToColor" />
            <converters:NullToVisibilityConverter x:Key="NullToVisibility" />

            <!-- Impeccable: Light theme. Physical scene: engineer debugging serial at a desk,
                 well-lit office or lab. Clean, professional, high contrast.
                 Color strategy: Restrained. Tinted neutrals + functional accents (green=RX, blue=TX) -->

            <!-- Base Colors -->
            <Color x:Key="BgBase">#F4F5F7</Color>
            <Color x:Key="BgSurface">#FFFFFF</Color>
            <Color x:Key="BgElevated">#EEEEF0</Color>
            <Color x:Key="BgHover">#E4E5E8</Color>
            <Color x:Key="BorderColor">#D4D6DD</Color>
            <Color x:Key="BorderLight">#B8BBC3</Color>

            <Color x:Key="InkPrimary">#1A1B1E</Color>
            <Color x:Key="InkSecondary">#6B6D76</Color>
            <Color x:Key="InkTertiary">#9CA0A8</Color>

            <Color x:Key="Accent">#3B6FD8</Color>
            <Color x:Key="AccentHover">#5282E6</Color>
            <Color x:Key="AccentPressed">#2F5CC0</Color>

            <Color x:Key="GreenRX">#16A34A</Color>
            <Color x:Key="GreenRxBg">#ECFDF5</Color>
            <Color x:Key="GreenRxBorder">#A7F3D0</Color>

            <Color x:Key="BlueTX">#2563EB</Color>
            <Color x:Key="BlueTxBg">#EFF6FF</Color>
            <Color x:Key="BlueTxBorder">#BFDBFE</Color>

            <Color x:Key="RedError">#DC2626</Color>

            <!-- Brushes -->
            <SolidColorBrush x:Key="BgBaseBrush" Color="{StaticResource BgBase}" />
            <SolidColorBrush x:Key="BgSurfaceBrush" Color="{StaticResource BgSurface}" />
            <SolidColorBrush x:Key="BgElevatedBrush" Color="{StaticResource BgElevated}" />
            <SolidColorBrush x:Key="BgHoverBrush" Color="{StaticResource BgHover}" />
            <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
            <SolidColorBrush x:Key="BorderLightBrush" Color="{StaticResource BorderLight}" />
            <SolidColorBrush x:Key="InkPrimaryBrush" Color="{StaticResource InkPrimary}" />
            <SolidColorBrush x:Key="InkSecondaryBrush" Color="{StaticResource InkSecondary}" />
            <SolidColorBrush x:Key="InkTertiaryBrush" Color="{StaticResource InkTertiary}" />
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
            <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHover}" />
            <SolidColorBrush x:Key="GreenRxBrush" Color="{StaticResource GreenRX}" />
            <SolidColorBrush x:Key="GreenRxBgBrush" Color="{StaticResource GreenRxBg}" />
            <SolidColorBrush x:Key="GreenRxBorderBrush" Color="{StaticResource GreenRxBorder}" />
            <SolidColorBrush x:Key="BlueTxBrush" Color="{StaticResource BlueTX}" />
            <SolidColorBrush x:Key="BlueTxBgBrush" Color="{StaticResource BlueTxBg}" />
            <SolidColorBrush x:Key="BlueTxBorderBrush" Color="{StaticResource BlueTxBorder}" />

            <!-- ======================== -->
            <!-- Impeccable: Typography — cap at 2 families. Segoe UI for UI, Consolas for data. -->
            <!-- ======================== -->

            <!-- Primary Action Button -->
            <Style TargetType="Button" x:Key="PrimaryButton">
                <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                <Setter Property="Foreground" Value="#FFFFFF" />
                <Setter Property="Padding" Value="14,8" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource AccentHoverBrush}" />
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Background" Value="{StaticResource AccentPressed}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Secondary Outline Button -->
            <Style TargetType="Button" x:Key="OutlineButton">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource InkSecondaryBrush}" />
                <Setter Property="Padding" Value="10,5" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource BgHoverBrush}" />
                        <Setter Property="Foreground" Value="{StaticResource InkPrimaryBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Tag/Pill Button for Quick Send -->
            <Style x:Key="TagButton" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource BgElevatedBrush}" />
                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                <Setter Property="Width" Value="75" />
                <Setter Property="Height" Value="26" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="FontFamily" Value="Consolas" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="13"
                                    Padding="0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource BgHoverBrush}" />
                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Small green action button -->
            <Style TargetType="Button" x:Key="GreenButton">
                <Setter Property="Background" Value="{StaticResource GreenRxBg}" />
                <Setter Property="Foreground" Value="{StaticResource GreenRxBrush}" />
                <Setter Property="Padding" Value="12,5" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{StaticResource GreenRxBorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#DCFCE7" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- ComboBox -->
            <Style TargetType="ComboBox">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Height" Value="30" />
                <Setter Property="Background" Value="{StaticResource BgElevatedBrush}" />
                <Setter Property="Foreground" Value="{StaticResource InkPrimaryBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="8,2" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid>
                                <Border x:Name="Border"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="5">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ContentPresenter Grid.Column="0"
                                                          Margin="{TemplateBinding Padding}"
                                                          Content="{TemplateBinding SelectionBoxItem}"
                                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Left" />
                                        <Path Grid.Column="1"
                                              Data="M0,0 L6,0 L3,4 Z"
                                              Fill="{StaticResource InkTertiaryBrush}"
                                              Margin="0,0,8,0"
                                              VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                                <Popup x:Name="Popup" IsOpen="{TemplateBinding IsDropDownOpen}"
                                       Placement="Bottom" StaysOpen="False"
                                       AllowsTransparency="True">
                                    <Border Background="{StaticResource BgElevatedBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="5"
                                            MaxHeight="200">
                                        <ScrollViewer>
                                            <ItemsPresenter />
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource BorderLightBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ComboBoxItem -->
            <Style TargetType="ComboBoxItem">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource InkPrimaryBrush}" />
                <Setter Property="Padding" Value="8,6" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBoxItem">
                            <Border Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource BgHoverBrush}" />
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{StaticResource BgHoverBrush}" />
                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- CheckBox -->
            <Style TargetType="CheckBox">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="{StaticResource InkSecondaryBrush}" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <Grid Margin="0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="CheckBoxBorder"
                                        Width="16" Height="16"
                                        Background="{StaticResource BgElevatedBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="3"
                                        VerticalAlignment="Center">
                                    <Path x:Name="CheckMark"
                                          Data="M3,8 L6,11 L12,4"
                                          Stroke="{StaticResource AccentBrush}"
                                          StrokeThickness="2"
                                          StrokeLineJoin="Round"
                                          Visibility="Collapsed" />
                                </Border>
                                <ContentPresenter Grid.Column="1"
                                                  Margin="6,0,0,0"
                                                  VerticalAlignment="Center"
                                                  Content="{TemplateBinding Content}" />
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- TextBlock label -->
            <Style x:Key="Label" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="{StaticResource InkSecondaryBrush}" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <!-- Section header label -->
            <Style x:Key="SectionHeader" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{StaticResource InkPrimaryBrush}" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <!-- TextBox -->
            <Style TargetType="TextBox">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Foreground" Value="{StaticResource InkPrimaryBrush}" />
                <Setter Property="Background" Value="{StaticResource BgSurfaceBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="8,4" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5">
                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderLightBrush}" />
                                </Trigger>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ListBoxItem (no selection highlight, clean) -->
            <Style TargetType="ListBoxItem">
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border Background="{TemplateBinding Background}"
                                    BorderThickness="0"
                                    Padding="{TemplateBinding Padding}"
                                    Margin="{TemplateBinding Margin}">
                                <ContentPresenter />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ScrollViewer (thin, dark scrollbars) -->
            <Style TargetType="ScrollViewer">
                <Setter Property="BorderThickness" Value="0" />
            </Style>

            <!-- StatusBar -->
            <Style TargetType="StatusBar">
                <Setter Property="Background" Value="{StaticResource BgBaseBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                <Setter Property="BorderThickness" Value="0,1,0,0" />
                <Setter Property="Padding" Value="12,6" />
            </Style>

            <!-- ScrollBar (dark themed) -->
            <Style TargetType="ScrollBar">
                <Setter Property="Width" Value="8" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid Background="{StaticResource BgBaseBrush}">
                                <Track x:Name="PART_Track" IsDirectionReversed="False">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageUpCommand" Background="Transparent" />
                                    </Track.DecreaseRepeatButton>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageDownCommand" Background="Transparent" />
                                    </Track.IncreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Background="{StaticResource BorderBrush}"
                                               BorderThickness="0"
                                               Width="6" />
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="Orientation" Value="Horizontal">
                                    <Setter Property="Height" Value="8" />
                                    <Setter Property="Width" Value="Auto" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Window style -->
            <Style TargetType="Window">
                <Setter Property="Background" Value="{StaticResource BgBaseBrush}" />
                <Setter Property="Foreground" Value="{StaticResource InkPrimaryBrush}" />
                <Setter Property="FontFamily" Value="Segoe UI" />
                <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
