<Window x:Class="ACCcom.SchemaEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ACCcom.ViewModels"
        xmlns:converters="clr-namespace:ACCcom.Converters"
        xmlns:local="clr-namespace:ACCcom"
        Title="{Binding [SchemaEditor.Title], Source={x:Static local:LanguageManager.Instance}}" Height="700" Width="850"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBaseBrush}">

    <Window.Resources>
        <converters:FieldValuesTemplateSelector x:Key="FieldValuesSelector">
            <converters:FieldValuesTemplateSelector.DefaultTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding ValuesText}" Foreground="{DynamicResource InkTertiaryBrush}" FontSize="11" VerticalAlignment="Center" />
                </DataTemplate>
            </converters:FieldValuesTemplateSelector.DefaultTemplate>
            <converters:FieldValuesTemplateSelector.EnumTemplate>
                <DataTemplate>
                    <Border BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1" CornerRadius="3" Background="{DynamicResource BgElevatedBrush}" Padding="4,1">
                        <TextBlock Text="{Binding ValuesText}" FontSize="11" VerticalAlignment="Center" Foreground="{DynamicResource InkPrimaryBrush}" />
                    </Border>
                </DataTemplate>
            </converters:FieldValuesTemplateSelector.EnumTemplate>
        </converters:FieldValuesTemplateSelector>

        <Style x:Key="FieldDataGridEdit" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserReorderColumns" Value="False" />
            <Setter Property="CanUserSortColumns" Value="False" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource DividerBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Background" Value="{DynamicResource BgSurfaceBrush}" />
            <Setter Property="RowBackground" Value="Transparent" />
            <Setter Property="AlternatingRowBackground" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource InkPrimaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="RowHeight" Value="26" />
            <Setter Property="ColumnHeaderHeight" Value="26" />
            <Setter Property="RowStyle">
                <Setter.Value>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="Transparent" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BgActiveBrush}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{DynamicResource BgSurfaceBrush}" />
                        <Setter Property="Foreground" Value="{DynamicResource InkSecondaryBrush}" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="FontSize" Value="11" />
                        <Setter Property="FontFamily" Value="Segoe UI" />
                        <Setter Property="Padding" Value="6,2" />
                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                        <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Padding" Value="6,0" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="Transparent" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PreviewTextBox" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource InkPrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: Schema-level params -->
        <Border Grid.Row="0" Background="{DynamicResource BgSurfaceBrush}"
                CornerRadius="6" Padding="10,8" Margin="0,0,0,6"
                BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding [SchemaEditor.Name], Source={x:Static local:LanguageManager.Instance}}" Style="{StaticResource Label}" Margin="0,0,4,0" />
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ParserName, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="11" Padding="4,1" Height="22" />
                <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding [SchemaEditor.Description], Source={x:Static local:LanguageManager.Instance}}" Style="{StaticResource Label}" Margin="0,0,4,0" />
                <TextBox Grid.Row="0" Grid.Column="4" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="11" Padding="4,1" Height="22" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding [SchemaEditor.Header], Source={x:Static local:LanguageManager.Instance}}" Style="{StaticResource Label}" Margin="0,6,4,0" />
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Header, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="11" Padding="4,1" Height="22" Margin="0,6,0,0" />
                <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding [SchemaEditor.Footer], Source={x:Static local:LanguageManager.Instance}}" Style="{StaticResource Label}" Margin="0,6,4,0" />
                <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding Footer, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="11" Padding="4,1" Height="22" Margin="0,6,0,0" Width="100" HorizontalAlignment="Left" />

                <StackPanel Grid.Row="1" Grid.Column="3" Orientation="Horizontal" Margin="0,6,0,0">
                    <TextBlock Text="{Binding [SchemaEditor.MinLength], Source={x:Static local:LanguageManager.Instance}}" Style="{StaticResource Label}" Margin="0,0,4,0" VerticalAlignment="Center" />
                    <TextBox Text="{Binding MinLength, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource NumericBox}" Width="44" Margin="0,0,12,0" />
                    <TextBlock Text="{Binding [SchemaEditor.Checksum], Source={x:Static local:LanguageManager.Instance}}" Style="{StaticResource Label}" Margin="0,0,4,0" VerticalAlignment="Center" />
                    <ComboBox ItemsSource="{x:Static vm:SchemaEditorViewModel.ChecksumTypes}"
                              SelectedItem="{Binding ChecksumType}"
                              Width="70" FontSize="11" Height="22" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: Field editor DataGrid -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DataGrid Grid.Row="0" Style="{StaticResource FieldDataGridEdit}"
                      ItemsSource="{Binding Fields}" SelectedItem="{Binding SelectedField, Mode=TwoWay}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{Binding [Column.Offset], Source={x:Static local:LanguageManager.Instance}}" Binding="{Binding Offset, UpdateSourceTrigger=PropertyChanged}" Width="55" />
                    <DataGridTextColumn Header="{Binding [Column.Name], Source={x:Static local:LanguageManager.Instance}}" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" MinWidth="80" Width="*" />
                    <DataGridTextColumn Header="{Binding [Column.Length], Source={x:Static local:LanguageManager.Instance}}" Binding="{Binding Length, Mode=OneWay}" Width="40" IsReadOnly="True" />
                    <DataGridTemplateColumn Header="{Binding [Column.Type], Source={x:Static local:LanguageManager.Instance}}" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Type}" VerticalAlignment="Center" FontSize="11" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{x:Static vm:SchemaEditorViewModel.FieldTypes}"
                                          SelectedItem="{Binding Type, UpdateSourceTrigger=PropertyChanged}"
                                          FontSize="11" Height="22" VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="{Binding [Column.Unit], Source={x:Static local:LanguageManager.Instance}}" Binding="{Binding Unit, UpdateSourceTrigger=PropertyChanged}" Width="50" />
                    <DataGridTemplateColumn Header="{Binding [Column.BE], Source={x:Static local:LanguageManager.Instance}}" Width="38">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding BigEndian, UpdateSourceTrigger=PropertyChanged}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="{Binding [Column.Values], Source={x:Static local:LanguageManager.Instance}}" Width="130"
                                            CellTemplateSelector="{StaticResource FieldValuesSelector}">
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding ValuesText, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="11" VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="{Binding [Column.Color], Source={x:Static local:LanguageManager.Instance}}" Binding="{Binding Color, UpdateSourceTrigger=PropertyChanged}" Width="70" />
                    <DataGridTemplateColumn Header="" Width="28">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="×" FontSize="12" Padding="2,0"
                                        Style="{StaticResource HeaderButton}"
                                        Foreground="{DynamicResource RedErrorBrush}"
                                        Command="{Binding DataContext.RemoveFieldCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Field action buttons -->
            <Border Grid.Row="1" Background="{DynamicResource BgSurfaceBrush}"
                    BorderThickness="0,1,0,0" BorderBrush="{DynamicResource DividerBrush}"
                    Padding="6,4">
                <StackPanel Orientation="Horizontal">
                    <Button Content="{Binding [SchemaEditor.AddField], Source={x:Static local:LanguageManager.Instance}}" Command="{Binding AddFieldCommand}"
                            Style="{StaticResource PrimaryButton}" FontSize="11" Height="24" Padding="10,0" Margin="0,0,6,0" />
                    <Button Content="{Binding [SchemaEditor.MoveUp], Source={x:Static local:LanguageManager.Instance}}" Command="{Binding MoveFieldUpCommand}"
                            Style="{StaticResource OutlineButton}" FontSize="11" Height="24" Padding="8,0" Margin="0,0,4,0" />
                    <Button Content="{Binding [SchemaEditor.MoveDown], Source={x:Static local:LanguageManager.Instance}}" Command="{Binding MoveFieldDownCommand}"
                            Style="{StaticResource OutlineButton}" FontSize="11" Height="24" Padding="8,0" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Row 2: Generate+Save row -->
        <Border Grid.Row="2" Background="{DynamicResource BgSurfaceBrush}"
                BorderThickness="0,0,0,1" BorderBrush="{DynamicResource DividerBrush}"
                Padding="6,4">
            <StackPanel Orientation="Horizontal">
                <Button Content="{Binding [SchemaEditor.Generate], Source={x:Static local:LanguageManager.Instance}}" Command="{Binding GenerateCommand}"
                        Style="{StaticResource PrimaryButton}" FontSize="11" Height="24" Padding="12,0" Margin="0,0,6,0" />
                <Button Content="{Binding [SchemaEditor.Save], Source={x:Static local:LanguageManager.Instance}}" Command="{Binding SaveCommand}"
                        Style="{StaticResource OutlineButton}" FontSize="11" Height="24" Padding="12,0" />
            </StackPanel>
        </Border>

        <!-- Row 3: Preview tabs -->
        <TabControl Grid.Row="3" Margin="0,6,0,6" Background="{DynamicResource BgSurfaceBrush}"
                     BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
            <TabItem Header="{Binding [Tab.JSON], Source={x:Static local:LanguageManager.Instance}}">
                <TextBox Style="{StaticResource PreviewTextBox}" Text="{Binding GeneratedJson, Mode=OneWay}" />
            </TabItem>
            <TabItem Header="{Binding [Tab.CsxCode], Source={x:Static local:LanguageManager.Instance}}">
                <TextBox Style="{StaticResource PreviewTextBox}" Text="{Binding GeneratedCode, Mode=OneWay}" />
            </TabItem>
            <TabItem Header="{Binding [Tab.TestParse], Source={x:Static local:LanguageManager.Instance}}">
                <Grid Margin="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="{Binding [SchemaEditor.HexData], Source={x:Static local:LanguageManager.Instance}}" Style="{StaticResource Label}" Margin="0,0,0,4" />
                    <Grid Grid.Row="1" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding TestHexInput, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas" FontSize="12" Padding="6,2" Height="26"
                                 Background="{DynamicResource BgElevatedBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" />
                        <Button Grid.Column="1" Content="{Binding [SchemaEditor.Parse], Source={x:Static local:LanguageManager.Instance}}" Command="{Binding TestParseCommand}"
                                Style="{StaticResource PrimaryButton}" Height="26" Margin="6,0,0,0" Padding="14,0" />
                    </Grid>
                    <TextBox Grid.Row="2" Style="{StaticResource PreviewTextBox}" Text="{Binding ParseResult, Mode=OneWay}" />
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Row 4: Bottom buttons -->
        <Border Grid.Row="4" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource DividerBrush}"
                Padding="0,6,0,0">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Content="{Binding [SchemaEditor.LoadTemplate], Source={x:Static local:LanguageManager.Instance}}" Command="{Binding LoadSchemaTemplateCommand}"
                        Style="{StaticResource OutlineButton}" FontSize="11" Height="26" Padding="12,0" Margin="0,0,8,0" />
                <Button Content="{Binding [SchemaEditor.SaveToParsers], Source={x:Static local:LanguageManager.Instance}}" Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButton}" FontSize="11" Height="26" Padding="14,0" Margin="0,0,8,0" />
                <Button Content="{Binding [SchemaEditor.Close], Source={x:Static local:LanguageManager.Instance}}" FontSize="11" Height="26" Padding="14,0"
                        Style="{StaticResource OutlineButton}" IsCancel="True" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
