<Window x:Class="ACCcom.StatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ACCcom"
        Title="{Binding [Stats.Title], Source={x:Static local:LanguageManager.Instance}}" Height="420" Width="380"
        MinHeight="350" MinWidth="320"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBaseBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="{Binding [Stats.Title], Source={x:Static local:LanguageManager.Instance}}" FontSize="16" FontWeight="SemiBold"
                   Foreground="{DynamicResource InkPrimaryBrush}" />

        <!-- Stats content -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- RX Section -->
                <TextBlock Text="{Binding [Stats.RXSection], Source={x:Static local:LanguageManager.Instance}}" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource StatusBlueBrush}" Margin="0,0,0,6" />
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,6">
                        <TextBlock Text="{Binding [Stats.BytesPerSec], Source={x:Static local:LanguageManager.Instance}}" FontSize="10" Foreground="{DynamicResource InkTertiaryBrush}" />
                        <TextBox Text="{Binding RxBytesPerSec}" FontFamily="Consolas" FontSize="18" FontWeight="Bold"
                                  Foreground="{DynamicResource InkPrimaryBrush}" IsReadOnly="True" IsTabStop="False" BorderThickness="0" Background="Transparent" Padding="0" />
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,6">
                        <TextBlock Text="{Binding [Stats.FramesPerSec], Source={x:Static local:LanguageManager.Instance}}" FontSize="10" Foreground="{DynamicResource InkTertiaryBrush}" />
                        <TextBox Text="{Binding RxFramesPerSec}" FontFamily="Consolas" FontSize="18" FontWeight="Bold"
                                  Foreground="{DynamicResource InkPrimaryBrush}" IsReadOnly="True" IsTabStop="False" BorderThickness="0" Background="Transparent" Padding="0" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,6">
                        <TextBlock Text="{Binding [Stats.TotalBytes], Source={x:Static local:LanguageManager.Instance}}" FontSize="10" Foreground="{DynamicResource InkTertiaryBrush}" />
                        <TextBox Text="{Binding TotalRxBytes}" FontFamily="Consolas" FontSize="14"
                                  Foreground="{DynamicResource InkSecondaryBrush}" IsReadOnly="True" IsTabStop="False" BorderThickness="0" Background="Transparent" Padding="0" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,6">
                        <TextBlock Text="{Binding [Stats.TotalFrames], Source={x:Static local:LanguageManager.Instance}}" FontSize="10" Foreground="{DynamicResource InkTertiaryBrush}" />
                        <TextBox Text="{Binding TotalRxFrames}" FontFamily="Consolas" FontSize="14"
                                  Foreground="{DynamicResource InkSecondaryBrush}" IsReadOnly="True" IsTabStop="False" BorderThickness="0" Background="Transparent" Padding="0" />
                    </StackPanel>
                </Grid>

                <!-- TX Section -->
                <TextBlock Text="{Binding [Stats.TXSection], Source={x:Static local:LanguageManager.Instance}}" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource InkSecondaryBrush}" Margin="0,0,0,6" />
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,6">
                        <TextBlock Text="{Binding [Stats.BytesPerSec], Source={x:Static local:LanguageManager.Instance}}" FontSize="10" Foreground="{DynamicResource InkTertiaryBrush}" />
                        <TextBox Text="{Binding TxBytesPerSec}" FontFamily="Consolas" FontSize="18" FontWeight="Bold"
                                  Foreground="{DynamicResource InkPrimaryBrush}" IsReadOnly="True" IsTabStop="False" BorderThickness="0" Background="Transparent" Padding="0" />
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,6">
                        <TextBlock Text="{Binding [Stats.FramesPerSec], Source={x:Static local:LanguageManager.Instance}}" FontSize="10" Foreground="{DynamicResource InkTertiaryBrush}" />
                        <TextBox Text="{Binding TxFramesPerSec}" FontFamily="Consolas" FontSize="18" FontWeight="Bold"
                                  Foreground="{DynamicResource InkPrimaryBrush}" IsReadOnly="True" IsTabStop="False" BorderThickness="0" Background="Transparent" Padding="0" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,6">
                        <TextBlock Text="{Binding [Stats.TotalBytes], Source={x:Static local:LanguageManager.Instance}}" FontSize="10" Foreground="{DynamicResource InkTertiaryBrush}" />
                        <TextBox Text="{Binding TotalTxBytes}" FontFamily="Consolas" FontSize="14"
                                  Foreground="{DynamicResource InkSecondaryBrush}" IsReadOnly="True" IsTabStop="False" BorderThickness="0" Background="Transparent" Padding="0" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,6">
                        <TextBlock Text="{Binding [Stats.TotalFrames], Source={x:Static local:LanguageManager.Instance}}" FontSize="10" Foreground="{DynamicResource InkTertiaryBrush}" />
                        <TextBox Text="{Binding TotalTxFrames}" FontFamily="Consolas" FontSize="14"
                                  Foreground="{DynamicResource InkSecondaryBrush}" IsReadOnly="True" IsTabStop="False" BorderThickness="0" Background="Transparent" Padding="0" />
                    </StackPanel>
                </Grid>

                <!-- Connection Section -->
                <TextBlock Text="{Binding [Stats.Connection], Source={x:Static local:LanguageManager.Instance}}" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource StatusGreenBrush}" Margin="0,0,0,6" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,6">
                        <TextBlock Text="{Binding [Stats.Duration], Source={x:Static local:LanguageManager.Instance}}" FontSize="10" Foreground="{DynamicResource InkTertiaryBrush}" />
                        <TextBox Text="{Binding ConnectionDuration}" FontFamily="Consolas" FontSize="14"
                                  Foreground="{DynamicResource InkPrimaryBrush}" IsReadOnly="True" IsTabStop="False" BorderThickness="0" Background="Transparent" Padding="0" />
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,6">
                        <TextBlock Text="{Binding [Stats.ErrorRate], Source={x:Static local:LanguageManager.Instance}}" FontSize="10" Foreground="{DynamicResource InkTertiaryBrush}" />
                        <TextBox Text="{Binding ErrorRate, StringFormat='{}{0} %'}" FontFamily="Consolas" FontSize="14"
                                  Foreground="{DynamicResource RedErrorBrush}" IsReadOnly="True" IsTabStop="False" BorderThickness="0" Background="Transparent" Padding="0" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,6">
                        <TextBlock Text="{Binding [Stats.AvgFrameInterval], Source={x:Static local:LanguageManager.Instance}}" FontSize="10" Foreground="{DynamicResource InkTertiaryBrush}" />
                        <TextBox Text="{Binding AvgFrameInterval, StringFormat='{}{0} ms'}" FontFamily="Consolas" FontSize="14"
                                  Foreground="{DynamicResource InkPrimaryBrush}" IsReadOnly="True" IsTabStop="False" BorderThickness="0" Background="Transparent" Padding="0" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
