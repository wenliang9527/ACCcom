<Window x:Class="ACCcom.FrameAssemblerConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Multi-Frame Assembly Config" Height="340" Width="400"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBaseBrush}"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <CheckBox Grid.Row="0" x:Name="EnabledCheckBox" Content="Enable multi-frame assembly"
                  Margin="0,0,0,12" FontSize="13" Foreground="{DynamicResource InkPrimaryBrush}" />

        <Border Grid.Row="1" Background="{DynamicResource BgSurfaceBrush}" CornerRadius="6" Padding="12,10" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Frame Header:" FontSize="12"
                           Foreground="{DynamicResource InkSecondaryBrush}" VerticalAlignment="Center" />
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="HeaderBox" Text="AA 55"
                         FontFamily="Consolas" FontSize="12" Padding="4,2" Margin="0,0,0,6" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Length Field Offset:" FontSize="12"
                           Foreground="{DynamicResource InkSecondaryBrush}" VerticalAlignment="Center" />
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="OffsetBox" Text="-1"
                         FontFamily="Consolas" FontSize="12" Padding="4,2" Margin="0,0,0,6" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Length Field Size:" FontSize="12"
                           Foreground="{DynamicResource InkSecondaryBrush}" VerticalAlignment="Center" />
                <ComboBox Grid.Row="2" Grid.Column="1" x:Name="SizeCombo"
                          FontSize="12" Padding="4,2" HorizontalAlignment="Left" Width="80">
                    <ComboBoxItem Content="1 byte" Tag="1" IsSelected="True" />
                    <ComboBoxItem Content="2 bytes" Tag="2" />
                </ComboBox>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="{DynamicResource BgSurfaceBrush}" CornerRadius="6" Padding="12,10" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Max Frame Size:" FontSize="12"
                           Foreground="{DynamicResource InkSecondaryBrush}" VerticalAlignment="Center" />
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="MaxFrameBox" Text="4096"
                         FontFamily="Consolas" FontSize="12" Padding="4,2" Margin="0,0,0,6" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Timeout (ms):" FontSize="12"
                           Foreground="{DynamicResource InkSecondaryBrush}" VerticalAlignment="Center" />
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="TimeoutBox" Text="2000"
                         FontFamily="Consolas" FontSize="12" Padding="4,2" />
            </Grid>
        </Border>

        <TextBlock Grid.Row="3" x:Name="HelperText"
                   Text="Set length offset to -1 to skip length-based assembly (frame completes immediately on header match)."
                   FontSize="11" Foreground="{DynamicResource InkTertiaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12" />

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Click="Ok_Click" Style="{StaticResource PrimaryButton}" Width="80" Margin="0,0,8,0" />
            <Button Content="Cancel" Click="Cancel_Click" Style="{StaticResource OutlineButton}" Width="80" />
        </StackPanel>
    </Grid>
</Window>
