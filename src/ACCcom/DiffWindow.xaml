<Window x:Class="ACCcom.DiffWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ACCcom"
        Title="{Binding [DiffWindow.Title], Source={x:Static local:LanguageManager.Instance}}" Height="520" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgBaseBrush}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Input area -->
        <Border Grid.Row="0" Padding="10" Background="{DynamicResource BgSurfaceBrush}" CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding [DiffWindow.FrameA], Source={x:Static local:LanguageManager.Instance}}" FontWeight="SemiBold" Margin="0,0,0,4"
                               Foreground="{DynamicResource StatusBlueBrush}" FontSize="12" />
                    <TextBox x:Name="HexBoxA" FontFamily="Consolas" FontSize="12"
                             AcceptsReturn="True" Height="60" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Text="" />
                </StackPanel>
                <Button Grid.Column="1" Content="{Binding [DiffWindow.Compare], Source={x:Static local:LanguageManager.Instance}}" Click="Compare_Click"
                        Style="{StaticResource PrimaryButton}" Margin="16,16,16,0"
                        Padding="20,4" VerticalAlignment="Top" />
                <StackPanel Grid.Column="2">
                    <TextBlock Text="{Binding [DiffWindow.FrameB], Source={x:Static local:LanguageManager.Instance}}" FontWeight="SemiBold" Margin="0,0,0,4"
                               Foreground="{DynamicResource StatusGreenBrush}" FontSize="12" />
                    <TextBox x:Name="HexBoxB" FontFamily="Consolas" FontSize="12"
                             AcceptsReturn="True" Height="60" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Text="" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Legend -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,4" HorizontalAlignment="Center">
            <Border Background="#3322C55E" CornerRadius="3" Padding="8,2" Margin="0,0,12,0">
                <TextBlock Text="{Binding [DiffWindow.Match], Source={x:Static local:LanguageManager.Instance}}" FontSize="11" Foreground="#22C55E" />
            </Border>
            <Border Background="#33EF4444" CornerRadius="3" Padding="8,2">
                <TextBlock Text="{Binding [DiffWindow.Diff], Source={x:Static local:LanguageManager.Instance}}" FontSize="11" Foreground="#EF4444" />
            </Border>
        </StackPanel>

        <!-- Byte-level diff display -->
        <Border Grid.Row="2" Background="{DynamicResource BgSurfaceBrush}" CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Frame A header -->
                <Border Grid.Row="0" Padding="10,6" BorderThickness="0,0,0,1"
                        BorderBrush="{DynamicResource DividerBrush}">
                    <TextBlock Text="{Binding [DiffWindow.FrameA], Source={x:Static local:LanguageManager.Instance}}" FontWeight="SemiBold" FontSize="12"
                               Foreground="{DynamicResource StatusBlueBrush}" />
                </Border>

                <!-- Frame A hex bytes -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8,4">
                    <TextBlock x:Name="DiffTextA" FontFamily="Consolas" FontSize="13"
                               Foreground="{DynamicResource InkPrimaryBrush}" TextWrapping="Wrap" />
                </ScrollViewer>

                <!-- Frame B header -->
                <Border Grid.Row="2" Padding="10,6" BorderThickness="0,1,0,1"
                        BorderBrush="{DynamicResource DividerBrush}">
                    <TextBlock Text="{Binding [DiffWindow.FrameB], Source={x:Static local:LanguageManager.Instance}}" FontWeight="SemiBold" FontSize="12"
                               Foreground="{DynamicResource StatusGreenBrush}" />
                </Border>

                <!-- Frame B hex bytes -->
                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Padding="8,4">
                    <TextBlock x:Name="DiffTextB" FontFamily="Consolas" FontSize="13"
                               Foreground="{DynamicResource InkPrimaryBrush}" TextWrapping="Wrap" />
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Summary -->
        <Border Grid.Row="3" Padding="10,6" Background="{DynamicResource BgSurfaceBrush}"
                CornerRadius="6" Margin="0,6,0,0">
            <TextBox x:Name="SummaryText" Text="{Binding [DiffWindow.SummaryHint], Source={x:Static local:LanguageManager.Instance}}"
                       FontSize="12" Foreground="{DynamicResource InkSecondaryBrush}"
                       HorizontalAlignment="Center" IsReadOnly="True" IsTabStop="False" BorderThickness="0" Background="Transparent" Padding="0" />
        </Border>
    </Grid>
</Window>
