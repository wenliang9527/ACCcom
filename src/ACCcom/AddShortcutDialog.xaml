<Window x:Class="ACCcom.AddShortcutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ACCcom"
        Title="{Binding [AddShortcut.Title], Source={x:Static local:LanguageManager.Instance}}"
        Width="480" Height="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgBaseBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="{Binding [AddShortcut.Name], Source={x:Static local:LanguageManager.Instance}}" Style="{StaticResource Label}" Margin="0,0,0,4" />
            <TextBox x:Name="NameBox" Text="{Binding [AddShortcut.DefaultName], Source={x:Static local:LanguageManager.Instance}}" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,4">
            <TextBlock Text="{Binding [AddShortcut.Command], Source={x:Static local:LanguageManager.Instance}}" Style="{StaticResource Label}" Margin="0,0,0,4" />
            <TextBox x:Name="CommandBox" Text="AT+" AcceptsReturn="False"
                     TextChanged="CommandBox_TextChanged" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <CheckBox x:Name="HexCheckBox" Content="{Binding [Check.HexMode], Source={x:Static local:LanguageManager.Instance}}" Checked="HexCheckBox_Changed" Unchecked="HexCheckBox_Changed" />
            <TextBlock x:Name="HexInfo" Text="" Style="{StaticResource Label}" Margin="12,0,0,0"
                       VerticalAlignment="Center" />
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{Binding [Button.Cancel], Source={x:Static local:LanguageManager.Instance}}" Style="{StaticResource OutlineButton}" Width="60" Margin="0,0,8,0"
                    Click="Cancel_Click" />
            <Button Content="{Binding [AddShortcut.Add], Source={x:Static local:LanguageManager.Instance}}" Style="{StaticResource PrimaryButton}" Width="60"
                    Click="Add_Click" />
        </StackPanel>
    </Grid>
</Window>
