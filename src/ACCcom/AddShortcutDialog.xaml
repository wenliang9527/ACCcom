<Window x:Class="ACCcom.AddShortcutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="添加快捷指令" Width="480" Height="220"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgBaseBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="名称" Style="{StaticResource Label}" Margin="0,0,0,4" />
            <TextBox x:Name="NameBox" Text="新指令" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,4">
            <TextBlock Text="命令" Style="{StaticResource Label}" Margin="0,0,0,4" />
            <TextBox x:Name="CommandBox" Text="AT+" AcceptsReturn="False"
                     TextChanged="CommandBox_TextChanged" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <CheckBox x:Name="HexCheckBox" Content="HEX 模式" Checked="HexCheckBox_Changed" Unchecked="HexCheckBox_Changed" />
            <TextBlock x:Name="HexInfo" Text="" Style="{StaticResource Label}" Margin="12,0,0,0"
                       VerticalAlignment="Center" />
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="取消" Style="{StaticResource OutlineButton}" Width="60" Margin="0,0,8,0"
                    Click="Cancel_Click" />
            <Button Content="添加" Style="{StaticResource PrimaryButton}" Width="60"
                    Click="Add_Click" />
        </StackPanel>
    </Grid>
</Window>
