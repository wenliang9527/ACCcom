<Window x:Class="ACCcom.ModbusConnectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MODBUS Connection" Height="250" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BgBaseBrush}"
        Style="{StaticResource WindowStyle}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Select MODBUS Transport" Style="{StaticResource SectionHeader}" Margin="0,0,0,12" />

        <Border Grid.Row="1" Background="{DynamicResource BgSurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12">
            <StackPanel>
                <RadioButton Content="RTU (Serial)" IsChecked="{Binding IsRtuMode}" Margin="0,0,0,8" FontSize="12" Foreground="{DynamicResource InkPrimaryBrush}" />
                <RadioButton Content="TCP (Ethernet)" IsChecked="{Binding IsTcpMode}" FontSize="12" Foreground="{DynamicResource InkPrimaryBrush}" />

                <StackPanel IsEnabled="{Binding IsTcpMode}" Margin="20,8,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Host:" Style="{StaticResource Label}" />
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Host}" Style="{StaticResource NumericBox}" Height="24" />
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Port:" Style="{StaticResource Label}" />
                        <TextBox Grid.Row="0" Grid.Column="4" Text="{Binding Port}" Style="{StaticResource NumericBox}" Height="24" />
                    </Grid>
                </StackPanel>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="2" Text="{Binding StatusText}" Style="{StaticResource Label}" Margin="0,8,0,0" Foreground="{DynamicResource AccentBrush}" />

        <Button Grid.Row="4" Content="Connect &amp; Open MODBUS Window"
                Command="{Binding ConnectCommand}"
                Style="{StaticResource PrimaryButton}"
                Height="32" FontSize="13" />
    </Grid>
</Window>
