<Window x:Class="ACCcom.ReplayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Session Replay" Height="160" Width="420"
        MinHeight="140" MinWidth="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BgBaseBrush}"
        Closing="Window_Closing">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Status text -->
        <TextBlock x:Name="StatusText" Grid.Row="0"
                   Text="Ready" FontSize="13"
                   Foreground="{DynamicResource InkPrimaryBrush}" />

        <!-- Progress bar -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ProgressBar x:Name="ProgressBar" Grid.Column="0"
                         Height="20" Minimum="0" Maximum="1"
                         Foreground="{DynamicResource AccentBrush}"
                         Background="{DynamicResource BgElevatedBrush}" />
            <TextBlock x:Name="ProgressText" Grid.Column="1"
                       Text="0/0" FontSize="11" FontFamily="Consolas"
                       Foreground="{DynamicResource InkSecondaryBrush}"
                       VerticalAlignment="Center" Margin="8,0,0,0" />
        </Grid>

        <!-- Controls -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="PlayPauseButton" Content="Play"
                    Width="80" Height="28" Margin="0,0,8,0"
                    Click="PlayPause_Click"
                    Style="{StaticResource OutlineButton}" />
            <Button Content="Stop" Width="80" Height="28" Margin="0,0,16,0"
                    Click="Stop_Click"
                    Style="{StaticResource OutlineButton}" />

            <TextBlock Text="Speed:" VerticalAlignment="Center"
                       Foreground="{DynamicResource InkSecondaryBrush}"
                       Margin="0,0,6,0" />
            <ComboBox x:Name="SpeedCombo" Width="80" Height="26"
                      SelectedIndex="1"
                      SelectionChanged="Speed_SelectionChanged">
                <ComboBoxItem Content="0.5x" Tag="0.5" />
                <ComboBoxItem Content="1x" Tag="1.0" />
                <ComboBoxItem Content="2x" Tag="2.0" />
                <ComboBoxItem Content="5x" Tag="5.0" />
                <ComboBoxItem Content="Instant" Tag="0" />
            </ComboBox>
        </StackPanel>
    </Grid>
</Window>
